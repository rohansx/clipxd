# clipxd reverse proxy + static SPA, with automatic HTTPS (Let's Encrypt).
# {$CLIPXD_DOMAIN} is supplied via Caddy's environment (set in deploy.sh / systemd).
#
# Routing: the backend owns the clip/api/auth surface; everything else is the React SPA.
#   /clip/*  → public share pages + per-clip JSON/video/query  (backend)
#   /clips, /ingest*, /import, /net, /auth/*, /settings/keys    (backend, auth-gated)
#   /  and  /assets/*                                            (static SPA)
#
# /ingest* (not just /ingest) is required: the streaming stage-upload endpoints live at
# /ingest/stage, /ingest/stage/:session, and /ingest/stage/:session/commit — an exact-path
# matcher would let all three fall through to the static file_server, which 405s on
# POST/PUT instead of reaching the backend.
#
# /settings/keys is listed as an EXACT path, not /settings* — the bare /settings route is
# the SPA's own client-side page and must keep falling through to the static handler (which
# serves index.html so React Router can take over); only its /settings/keys BYOK API call
# belongs to the backend.

{$CLIPXD_DOMAIN} {
	encode zstd gzip

	# Security headers — applied to every response so a stray 404 from
	# the file_server can't leak with no headers at all.
	header {
		# HSTS: 2 years, include subdomains, preload-ready.
		Strict-Transport-Security "max-age=63072000; includeSubDomains"
		# Cross-origin isolation — required for SharedArrayBuffer if we
		# ever turn it on, otherwise a free defensive win.
		Cross-Origin-Opener-Policy "same-origin"
		# No embedding — clipxd is an app, not a frame target.
		X-Frame-Options "DENY"
		# Sensible referrer policy.
		Referrer-Policy "strict-origin-when-cross-origin"
		# Disable powerful features we don't use.
		Permissions-Policy "geolocation=(), microphone=(), camera=(), interest-cohort=()"
		# Block MIME sniffing.
		X-Content-Type-Options "nosniff"
	}

	# Backend surface
	@backend path /clip/* /clips /ingest* /import /net /auth/* /u/* /settings/keys
	handle @backend {
		reverse_proxy 127.0.0.1:8787
	}

	# Static single-page app (Vite build output)
	@assets path /assets/*
	handle @assets {
		root * /var/www/clipxd
		# Vite hashes asset filenames, so a 1-year immutable cache is safe
		# (a content change = new hash = new URL).
		header Cache-Control "public, max-age=31536000, immutable"
		file_server
	}

	@staticfile path /favicon.svg /favicon.*.png /og-image.svg /og-image.* /robots.txt /sitemap.xml /manifest.json
	handle @staticfile {
		root * /var/www/clipxd
		# Same as assets but shorter — these are referenced by name from
		# crawlers and may be edited in place.
		header Cache-Control "public, max-age=86400"
		file_server
	}

	handle {
		root * /var/www/clipxd
		try_files {path} /index.html
		# Don't let the SPA HTML get cached aggressively — clients expect
		# new deploys to show up on refresh.
		header Cache-Control "public, max-age=0, must-revalidate"
		file_server
	}

	# Large uploads (screen recordings) go through /ingest
	request_body {
		max_size 512MB
	}
}